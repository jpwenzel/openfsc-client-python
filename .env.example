# OpenFSC Server Configuration
OPENFSC_URL=wss://fsc.sandbox.euca.pacelink.net/ws/text

# Authentication Credentials
# Obtain these from your PACE account or OpenFSC server administrator
OPENFSC_SITE_ACCESS_KEY=your-site-access-key-uuid-here
OPENFSC_SITE_SECRET=your-secret-here

# POS Adapter Plugin (optional)
# Format: module_name.ClassName
POS_ADAPTER_CLASS=example_pos_adapter.ExamplePosAdapter
